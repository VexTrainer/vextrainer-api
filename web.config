<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>

      <!-- ASP.NET Core handler -->
      <handlers>
        <add name="aspNetCore" path="*" verb="*"
             modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>

      <aspNetCore processPath="dotnet"
                  arguments=".\VexTrainerAPI.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>

      <!-- Remove IIS Server header -->
      <security>
        <requestFiltering removeServerHeader="true">
          <!-- API payloads — 5 MB ceiling covers all quiz/lesson requests -->
          <requestLimits maxAllowedContentLength="5242880" />
        </requestFiltering>
      </security>

      <!-- Security response headers -->
      <httpProtocol>
        <customHeaders>
          <remove name="X-Powered-By" />
          <remove name="X-AspNet-Version" />
          <add name="X-Content-Type-Options" value="nosniff" />
          <add name="X-Frame-Options"        value="DENY" />
          <add name="X-XSS-Protection"       value="1; mode=block" />
          <add name="Referrer-Policy"        value="strict-origin-when-cross-origin" />
          <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
          <!-- API is never embedded in a frame and never needs camera/geo -->
          <add name="Permissions-Policy"     value="camera=(), microphone=(), geolocation=()" />
        </customHeaders>
      </httpProtocol>

      <!-- URL rewriting -->
      <rewrite>
        <rules>

          <!-- 1. HTTPS redirect — must be first -->
          <rule name="Redirect to HTTPS" stopProcessing="true">
            <match url="(.*)" />
            <conditions>
              <add input="{HTTPS}" pattern="^OFF$" />
            </conditions>
            <action type="Redirect" url="https://{HTTP_HOST}/{R:1}"
                    redirectType="Permanent" />
          </rule>

          <!-- 2. Block common exploit/scan attempts -->
          <!-- These will never be valid API paths and signal automated scanning -->
          <rule name="BlockMaliciousRequests" stopProcessing="true">
            <match url=".*" />
            <conditions logicalGrouping="MatchAny">
              <add input="{URL}" pattern="\.php$"          ignoreCase="true" />
              <add input="{URL}" pattern="\.cgi$"          ignoreCase="true" />
              <add input="{URL}" pattern="\.jsp$"          ignoreCase="true" />
              <add input="{URL}" pattern="/cgi-bin/"       ignoreCase="true" />
              <add input="{URL}" pattern="wp-"             ignoreCase="true" />
              <add input="{URL}" pattern="wordpress"       ignoreCase="true" />
              <add input="{URL}" pattern="joomla"          ignoreCase="true" />
              <add input="{URL}" pattern="/administrator/" ignoreCase="true" />
              <add input="{URL}" pattern="phpmyadmin"      ignoreCase="true" />
              <add input="{URL}" pattern="\.env"           ignoreCase="true" />
              <add input="{URL}" pattern="\.git"           ignoreCase="true" />
              <add input="{URL}" pattern="web\.config"     ignoreCase="true" />
              <add input="{URL}" pattern="appsettings"     ignoreCase="true" />
              <add input="{URL}" pattern="\.\."            ignoreCase="true" />
              <add input="{URL}" pattern="\.sql$"          ignoreCase="true" />
              <add input="{URL}" pattern="\.bak$"          ignoreCase="true" />
              <add input="{URL}" pattern="shell"           ignoreCase="true" />
              <add input="{URL}" pattern="xmlrpc"          ignoreCase="true" />
            </conditions>
            <action type="AbortRequest" />
          </rule>

        </rules>

        <!-- Strip server identification from outbound headers -->
        <outboundRules>
          <rule name="Remove Server Header">
            <match serverVariable="RESPONSE_Server" pattern=".+" />
            <action type="Rewrite" value="" />
          </rule>
          <rule name="Remove X-Powered-By Header">
            <match serverVariable="RESPONSE_X-Powered-By" pattern=".+" />
            <action type="Rewrite" value="" />
          </rule>
        </outboundRules>
      </rewrite>

    </system.webServer>
  </location>
</configuration>
